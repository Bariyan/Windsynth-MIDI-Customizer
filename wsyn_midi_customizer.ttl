@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix urid:  <http://lv2plug.in/ns/ext/urid#> .
@prefix opts:  <http://lv2plug.in/ns/ext/options#> .
@prefix bufsz: <http://lv2plug.in/ns/ext/buf-size#> .
@prefix rsz:   <http://lv2plug.in/ns/ext/resize-port#> .
@prefix pprop: <http://lv2plug.in/ns/ext/port-props#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<urn:bariyan:wsyn-midi-customizer>
    a lv2:Plugin ;
    doap:name "Windsynth MIDI Customizer" ;
    doap:maintainer [
        foaf:name "Atsushi Nishihata(Bariyan)"
    ] ;
    lv2:requiredFeature urid:map ;
    lv2:optionalFeature opts:options , rsz:resize ;
    opts:supportedOption bufsz:sequenceSize ;
    lv2:port
    [
        a lv2:InputPort , atom:AtomPort ;
        lv2:index 0 ;
        lv2:symbol "midi_in" ;
        lv2:name "MIDI In" ;
        atom:bufferType atom:Sequence ;
        atom:supports midi:MidiEvent ;
    ] ,
    [
        a lv2:OutputPort , atom:AtomPort ;
        lv2:index 1 ;
        lv2:symbol "midi_out" ;
        lv2:name "MIDI Out" ;
        atom:bufferType atom:Sequence ;
        atom:supports midi:MidiEvent ;
        rsz:minimumSize 8192 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 2 ;
        lv2:symbol "center_in" ;
        lv2:name "Calibration Center" ;
        lv2:default 8192 ;
        lv2:minimum 0 ;
        lv2:maximum 16383 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 16383 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 3 ;
        lv2:symbol "deadzone" ;
        lv2:name "DeadZone (±)" ;
        lv2:default 700 ;
        lv2:minimum 0 ;
        lv2:maximum 4000 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 4000 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "dist_u" ;
        lv2:name "Upper Reach Distance" ;
        lv2:default 4000 ;
        lv2:minimum 0 ;
        lv2:maximum 16383 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 16383 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "dist_l" ;
        lv2:name "Lower Reach Distance" ;
        lv2:default 4000 ;
        lv2:minimum 0 ;
        lv2:maximum 16383 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 16383 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 6 ;
        lv2:symbol "curve_u" ;
        lv2:name "Upper Curve/Depth" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 10 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 10 ;
        lv2:scalePoint [ rdfs:label "Linear" ; rdf:value 0.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=1)" ; rdf:value 1.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=2)" ; rdf:value 2.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=3)" ; rdf:value 3.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=4)" ; rdf:value 4.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=5)" ; rdf:value 5.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=1)" ; rdf:value 6.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=2)" ; rdf:value 7.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=3)" ; rdf:value 8.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=4)" ; rdf:value 9.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=5)" ; rdf:value 10.0 ] ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 7 ;
        lv2:symbol "curve_l" ;
        lv2:name "Lower Curve/Depth" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 10 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 10 ;
        lv2:scalePoint [ rdfs:label "Linear" ; rdf:value 0.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=1)" ; rdf:value 1.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=2)" ; rdf:value 2.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=3)" ; rdf:value 3.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=4)" ; rdf:value 4.0 ] ;
        lv2:scalePoint [ rdfs:label "Exp (k=5)" ; rdf:value 5.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=1)" ; rdf:value 6.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=2)" ; rdf:value 7.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=3)" ; rdf:value 8.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=4)" ; rdf:value 9.0 ] ;
        lv2:scalePoint [ rdfs:label "Log (k=5)" ; rdf:value 10.0 ] ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 8 ;
        lv2:symbol "v_floor" ;
        lv2:name "Pseudo Dynamic Velocity (0=Off, 1~= Floor)" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 127 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 127 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 9 ;
        lv2:symbol "transpose" ;
        lv2:name "Transpose (Semitones)" ;
        lv2:default 0 ;
        lv2:minimum -36 ;
        lv2:maximum 36 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 72 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 10 ;
        lv2:symbol "vel0_as_noteoff" ;
        lv2:name "Vel-Zero Fix(NoteOn Vel0 as NoteOff 0=Off, 1=On)" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 1 ;
        lv2:portProperty lv2:toggled ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 11 ;
        lv2:symbol "channel" ;
        lv2:name "Channel (0=Any, 1..16)" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 16 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 16 ;
    ] ,
    [
        a lv2:InputPort , lv2:ControlPort ;
        lv2:index 12 ;
        lv2:symbol "out_capacity" ;
        lv2:name "Output Capacity" ;
        lv2:default 0 ;
        lv2:minimum 0 ;
        lv2:maximum 16 ;
        lv2:portProperty lv2:integer ;
        pprop:rangeSteps 16 ;
        lv2:scalePoint [ rdfs:label "0=auto" ; rdf:value 0.0 ] ;
        lv2:scalePoint [ rdfs:label "1=4096" ; rdf:value 1.0 ] ;
        lv2:scalePoint [ rdfs:label "2=8192" ; rdf:value 2.0 ] ;
        lv2:scalePoint [ rdfs:label "4=16384" ; rdf:value 4.0 ] ;
    ] ,
    [
        a lv2:ControlPort , lv2:OutputPort ;
        lv2:index 13 ;
        lv2:symbol "pitch_bend_meter" ;
        lv2:name "Pitch Bend" ;
        lv2:minimum -8192.0 ;
        lv2:maximum 8191.0 ;
        lv2:default 0.0
    ] , 
    [
        a lv2:ControlPort , lv2:OutputPort ;
        lv2:index 14 ;
        lv2:symbol "breath_meter" ;
        lv2:name "Breath" ;
        lv2:minimum 0.0 ;
        lv2:maximum 127.0 ;
        lv2:default 0.0
    ] .
